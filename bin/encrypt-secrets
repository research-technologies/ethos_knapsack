#!/usr/bin/env ruby
# frozen_string_literal: true

# Encrypt plain-text secrets in ops/provision/ (backend, kubeconfig, k8s values).
# Run from repo root: bin/encrypt-secrets

parent_dir = File.dirname(__dir__)
provision_dir = File.join(parent_dir, 'ops', 'provision')

unless Dir.exist?(provision_dir)
  puts "ops/provision/ not found"
  exit 1
end

# ops/provision/ root: .backend, kube_config.yml
Dir.chdir(provision_dir)
['.backend', 'kube_config.yml'].each do |plain|
  next unless File.file?(plain)
  enc = plain == '.backend' ? '.backend.enc' : 'kube_config.enc.yml'
  cmd = "sops --encrypt #{plain} > #{enc}"
  puts cmd
  `#{cmd}`
end

# ops/provision/envs: *.secret.tfvars → *.secret.tfvars.enc (sensitive Terraform vars)
provision_envs = File.join(provision_dir, 'envs')
if Dir.exist?(provision_envs)
  Dir.chdir(provision_envs)
  Dir.glob("*.secret.tfvars").each do |file|
    next if file.include?('.enc')
    output_file = "#{file}.enc"
    cmd = "sops --encrypt #{file} > #{output_file}"
    puts cmd
    `#{cmd}`
  end
end

# ops/provision/k8s: *-values.yaml and optional cloudflare-api-token-secret.yaml
provision_k8s = File.join(provision_dir, 'k8s')
if Dir.exist?(provision_k8s)
  Dir.chdir(provision_k8s)
  Dir.glob("*-values.yaml").each do |file|
    next if file.include?('.enc')
    file_name = file.split('.')
    file_name.insert(-2, 'enc')
    output_file = file_name.join('.')
    cmd = "sops --encrypt #{file} > #{output_file}"
    puts cmd
    `#{cmd}`
  end
  if File.file?('cloudflare-api-token-secret.yaml')
    cmd = "sops --encrypt cloudflare-api-token-secret.yaml > cloudflare-api-token-secret.enc.yaml"
    puts cmd
    `#{cmd}`
  end
end
