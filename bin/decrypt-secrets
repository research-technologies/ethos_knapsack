#!/usr/bin/env ruby
# frozen_string_literal: true

# Decrypt SOPS-encrypted secrets in ops/provision/ (backend, kubeconfig, k8s values).
# Run from repo root: bin/decrypt-secrets

parent_dir = File.dirname(__dir__)
provision_dir = File.join(parent_dir, 'ops', 'provision')

unless Dir.exist?(provision_dir)
  puts "ops/provision/ not found"
  exit 1
end

# ops/provision/ root: .backend.enc, kube_config.enc.yml
Dir.chdir(provision_dir)
%w[.backend.enc kube_config.enc.yml].each do |enc|
  next unless File.file?(enc)
  out = enc == 'kube_config.enc.yml' ? 'kube_config.yml' : '.backend'
  cmd = "sops --decrypt #{enc} > #{out}"
  puts cmd
  `#{cmd}`
end

# ops/provision/envs: *.secret.tfvars.enc → *.secret.tfvars (sensitive Terraform vars, e.g. site24x7_key)
provision_envs = File.join(provision_dir, 'envs')
if Dir.exist?(provision_envs)
  Dir.chdir(provision_envs)
  Dir.glob("*.secret.tfvars.enc").each do |file|
    out = file.sub(/\.enc$/, '')
    cmd = "sops --decrypt #{file} > #{out}"
    puts cmd
    `#{cmd}`
  end
end

# ops/provision/k8s: *-values.enc.yaml and optional cloudflare-api-token-secret.enc.yaml
provision_k8s = File.join(provision_dir, 'k8s')
if Dir.exist?(provision_k8s)
  Dir.chdir(provision_k8s)
  Dir.glob("*-values.enc.yaml").each do |file|
    out = file.gsub(/\.enc/, '')
    cmd = "sops --decrypt #{file} > #{out}"
    puts cmd
    `#{cmd}`
  end
  if File.file?('cloudflare-api-token-secret.enc.yaml')
    cmd = "sops --decrypt cloudflare-api-token-secret.enc.yaml > cloudflare-api-token-secret.yaml"
    puts cmd
    `#{cmd}`
  end
end
