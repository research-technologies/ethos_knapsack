<div class="hamburger">
      <div class="line1"></div>
      <div class="line2"></div>
      <div class="line3"></div>
</div>
<nav class="menu navbar bg-light navbar-expand-sm justify-content-between align-items-center px-2 py-3 border-bottom" role="navigation" aria-label="Root Menu">
    <ul class="nav navbar-nav col-sm-10">
      <li class="nav-item <%= 'active font-weight-bold' if current_page?(hyrax.root_path) %>">
        <a class="nav-link" href="https://bl.uk" target="_blank"><span class="fa fa-external-link"></span> British Library Website</a>
        <div class="nav-divider"></div>
      </li>
      <li class="nav-item <%= 'active font-weight-bold' if current_page?(hyrax.root_path) %>">
        <%= link_to t(:'hyrax.controls.home'), hyrax.root_path, class: "nav-link", aria: current_page?(hyrax.root_path) ? {current: 'page'} : nil %>
        <div class="nav-divider"></div>
      </li>
      <li class="nav-item <%= 'active font-weight-bold' if current_page?(hyrax.about_path) %>">
        <%= link_to t(:'hyrax.controls.about'), hyrax.about_path, class: "nav-link", aria: current_page?(hyrax.about_path) ? {current: 'page'} : nil %>
        <div class="nav-divider"></div>
      </li>
      <li class="nav-item <%= 'active font-weight-bold' if current_page?(hyrax.help_path) %>">
        <%= link_to 'FAQs', hyrax.help_path, class: "nav-link", aria: current_page?(hyrax.help_path) ? {current: 'page'} : nil %>
        <div class="nav-divider"></div>
      </li>
      <li class="nav-item <%= 'active font-weight-bold' if current_page?('/contact_us') %>">
        <%= link_to t(:'hyrax.controls.contact'), '/contact_us', class: "nav-link", aria: current_page?('/contact_us') ? {current: 'page'} : nil %>
        <!--<a class="nav-link" aria-current="page" href="https://www.bl.uk/about/contact" target="_blank"><span class="fa fa-external-link"></span> <%#= t(:'hyrax.controls.contact') %></a> -->
      </li>
    </ul>
    <%#= render '/user_util_links' %>
</nav>
<script>
  /* hamburger.js */
  $( document ).ready(function() {

    const menu = document.querySelector(".menu");
    let open;
        
    function openMenu() {
      if (open) {
        menu.style.display = "none";
        open = false;
      } else if (!open) {
        menu.style.display = "block";
        open = true;
      }
    }

    $(".hamburger").on("click", function(){
      openMenu();
    });

    var logo = $("#bl_logo"), // Get the logo
 	logoHeight = logo.height(), // Get logo height
 	scrollTo = logoHeight;

    $(window).on("scroll", function() {
      var yPos = $(this).scrollTop(),
          yPer = (yPos / scrollTo);

      if (yPer < 1) {
         yPer = 1;
      }

      var logoPos = ((yPer * logoHeight) - logoHeight); // Calculate position of logo starting from minus the height of itself

      // Change the transform and opacity of the header
      $('#bl_logo').css({
        //transform: "translate3d(0," + headerPos + "px,0)",
    	top: -logoPos,
        opacity: (2-yPer)
      });
    
    });

  });
</script>


